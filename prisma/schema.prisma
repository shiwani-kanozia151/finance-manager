generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id     Int    @id @default(autoincrement())
  name   String
  email  String @unique
  password String
  role   String
  records Record[]
}

model Record {
  id       Int @id @default(autoincrement())
  amount   Float
  type     String
  category String
  note     String?
  userId   Int
  user     User @relation(fields: [userId], references: [id])
}